# Umami Analytics Configuration
#
# Setup steps:
# 1. Go to https://umami.is/ and create an account (or self-host)
# 2. Add your website in the dashboard
# 3. Copy the Website ID from Settings
# 4. Copy this file to .env.local and fill in the values

# Your Umami Website ID (required)
NEXT_PUBLIC_UMAMI_WEBSITE_ID=your-website-id-here

# Umami URL (optional, defaults to https://analytics.umami.is)
# For self-hosted, use your own domain:
# NEXT_PUBLIC_UMAMI_URL=https://your-analytics-domain.com
